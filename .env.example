# Postgres (локальний Docker, з docker-compose.yml)
DATABASE_URL=postgresql://psich:psich@localhost:5432/psich?schema=public

# API
NODE_ENV=development
API_PORT=4000
API_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# JWT (Phase 2)
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Google OAuth (Phase 2)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/auth/google/callback

# LiqPay (Phase 3)
LIQPAY_PUBLIC_KEY=
LIQPAY_PRIVATE_KEY=

# Monobank Acquiring (Phase 3)
MONO_TOKEN=

# Cloudinary (Phase 4)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email (Phase 5/6)
RESEND_API_KEY=
EMAIL_FROM=noreply@psyplatform.local

# Web
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Admin
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:4000
